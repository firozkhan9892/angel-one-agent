# Angel One Trading Agent - Configuration Template
# Copy this to .env and fill in your credentials

# ============================================
# ANGEL ONE SMARTAPI CREDENTIALS
# ============================================
# Get from: https://www.angelbroking.com/
API_KEY=your_api_key_here
CLIENT_ID=your_client_id_here
PASSWORD=your_password_here
TOTP_SECRET=your_totp_secret_here

# ============================================
# TRADING SETTINGS
# ============================================
# Symbol to trade
SYMBOL=RELIANCE

# Exchange: NSE, BSE, NFO, MCX
EXCHANGE=NSE

# Interval: ONE_MINUTE, FIVE_MINUTE, FIFTEEN_MINUTE
INTERVAL=FIVE_MINUTE

# Quantity per trade
TRADE_QUANTITY=1

# ============================================
# TELEGRAM NOTIFICATIONS
# ============================================
# Create bot via @BotFather on Telegram
TELEGRAM_BOT_TOKEN=your_bot_token_here
TELEGRAM_CHAT_ID=your_chat_id_here
TELEGRAM_ENABLED=true

# ============================================
# FINNHUB NEWS API
# ============================================
# Get free key from: https://finnhub.io
FINNHUB_API_KEY=your_finnhub_key_here
NEWS_ENABLED=true

# ============================================
# RISK MANAGEMENT
# ============================================
# Total account size in rupees
ACCOUNT_SIZE=10000

# Risk per trade as decimal (0.02 = 2%)
RISK_PER_TRADE=0.02

# Max drawdown threshold before pausing (0.15 = 15%)
MAX_DRAWDOWN_THRESHOLD=0.15

# ============================================
# DASHBOARD SETTINGS
# ============================================
# Flask debug mode (True/False)
FLASK_DEBUG=False

# Port for dashboard
PORT=5000

# ============================================
# LOGGING
# ============================================
# Log level: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO

# ============================================
# ADVANCED SETTINGS (Optional)
# ============================================
# Database path
DB_PATH=data/trading_agent.db

# CSV log path
CSV_LOG_PATH=output/signals_log.csv

# Backtest reports path
BACKTEST_PATH=backtest_reports/

# Keep-alive ping interval (seconds)
KEEPALIVE_INTERVAL=300
